PORT=4500
ALLOW_ORIGINS=http://localhost:5173

# Resend configuration (MAIL_TO is used for contact form fallback; verification envoie au user)
RESEND_API_KEY=re_replace_me
# Utiliser le domaine sandbox Resend tant que woodtech.cloud n'est pas 100% vérifié
MAIL_FROM=WoodTech <notifications@example.com>
MAIL_TO=contact@example.com

# Option SMTP (Gmail app password). Si EMAIL_USER/PASS sont renseignés, l'envoi passe par Gmail.
EMAIL_USER=
EMAIL_PASS=
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
